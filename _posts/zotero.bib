  file = {/home/shun/Dropbox/Zotero/IRL/Learning to Understand Goal Specifications by Modelling Reward_Bahdanau et al_2018.pdf;/home/shun/Zotero/storage/XQGWIDY3/1806.html},
  journal = {arXiv:1806.01946 [cs]},
